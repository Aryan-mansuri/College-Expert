{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Stores user notification preferences and profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "notificationPreferences": {
          "type": "object",
          "properties": {
            "entranceExams": { "type": "boolean" },
            "results": { "type": "boolean" },
            "counseling": { "type": "boolean" }
          }
        }
      },
      "required": ["uid", "email"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile and notification settings."
    }
  }
}
